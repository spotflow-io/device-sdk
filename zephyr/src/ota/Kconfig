menuconfig SPOTFLOW_OTA
	bool "Enable Spotflow over-the-air (OTA) updates"
	depends on SPOTFLOW && BOOTLOADER_MCUBOOT
	select SETTINGS
	select FLASH
	select FLASH_MAP
	select STREAM_FLASH
	select IMG_MANAGER
	select IMG_ERASE_PROGRESSIVELY
	select REBOOT
	select HTTP_CLIENT
	default n

if SPOTFLOW_OTA

config HEAP_MEM_POOL_ADD_SIZE_SPOTFLOW_OTA
	int "Additional heap size required by Spotflow OTA"
	# TODO: Find adequate value (this is probably too much)
	default 32768
	help
		Additional heap size required by Spotflow OTA.
		Increase this value if you experience issues with OTA updates.

config SPOTFLOW_OTA_DOWNLOAD_THREAD_STACK_SIZE
	int "Stack size for the OTA download thread"
	default 4096
	help
	  Stack size in bytes for the dedicated OTA firmware download thread.
	  Increase if you observe stack overflows during TLS or HTTP operations.

config SPOTFLOW_OTA_MAX_ARTIFACTS
	int "Maximum number of artifacts in an OTA update manifest"
	default 4
	range 1 32
	help
	  Maximum number of firmware artifacts accepted in one OTA update manifest.

config SPOTFLOW_OTA_THREAD_STACK_SIZE
	int "Stack size for the OTA worker thread"
	default 4096
	help
	  Stack size in bytes for the OTA worker thread.

config SPOTFLOW_OTA_HTTP_TIMEOUT_MS
	int "HTTP timeout for artifact downloads in milliseconds"
	default 120000
	help
	  Maximum time allowed for a single artifact download HTTP request.

config SPOTFLOW_OTA_DOWNLOAD_BUFFER_SIZE
	int "Receive buffer size for artifact downloads in bytes"
	default IMG_BLOCK_BUF_SIZE if IMG_MANAGER
	default 512
	help
	  Size of the HTTP response receive buffer used while streaming artifacts.
	  When main-firmware image management is enabled, defaults to the image
	  writer buffer size so download and flash paths can share the same block size.

config SPOTFLOW_OTA_DOWNLOAD_RETRY_DELAY_MS
	int "Delay between transient artifact download retries in milliseconds"
	default 5000
	help
	  Delay before retrying an artifact download after a transient failure.

endif # SPOTFLOW_OTA
