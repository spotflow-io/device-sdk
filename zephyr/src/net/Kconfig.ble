config SPOTFLOW_TRANSPORT_BLE
	bool "BLE gateway transport"
	select BT
	select BT_PERIPHERAL

if SPOTFLOW_TRANSPORT_BLE

config SPOTFLOW_BLE_ATT_MTU
	int "Maximum supported BLE ATT MTU"
	default 247
	range 23 247
	help
		Maximum ATT MTU this device supports for the Spotflow BLE transport.
		The negotiated ATT MTU for a connection may still be lower, depending on
		the central capabilities and whether the central initiates MTU exchange.

configdefault BT_L2CAP_TX_MTU
	default SPOTFLOW_BLE_ATT_MTU
	help
		Match the Bluetooth L2CAP TX MTU to the maximum ATT MTU advertised by
		the Spotflow BLE transport so larger Spotflow frames do not get limited
		by a smaller host-side L2CAP payload configuration.

configdefault BT_BUF_ACL_TX_SIZE
	default 251
	help
		Use a full data-length ACL TX buffer so common 247-byte ATT MTU
		notifications fit into a single BLE data packet without extra
		fragmentation in the controller/host path.

configdefault BT_BUF_ACL_RX_SIZE
	default 251
	help
		Keep the ACL RX buffer aligned with the TX side and with the common
		247-byte ATT MTU case so incoming Spotflow control/config traffic is not
		artificially constrained by smaller host receive buffers.

endif # SPOTFLOW_TRANSPORT_BLE
